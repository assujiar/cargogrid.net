# Supabase project settings.
# Set these in Vercel Project Settings > Environment Variables and keep the same
# keys in your local .env.local when developing.
NEXT_PUBLIC_SUPABASE_URL="https://gfsqmbeiatbwmtktbpkc.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_YtRERprptdXdmLhlbnRHWQ_1niYWAP7"
# Legacy alias supported by src/lib/supabase.ts for older deployments.
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_YtRERprptdXdmLhlbnRHWQ_1niYWAP7"

# Server-only Supabase settings. Never expose SUPABASE_SECRET_KEY to the browser.
SUPABASE_URL="https://gfsqmbeiatbwmtktbpkc.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_YtRERprptdXdmLhlbnRHWQ_1niYWAP7"
SUPABASE_SECRET_KEY="YOUR_SUPABASE_SECRET_KEY"
SUPABASE_JWKS_URL="https://gfsqmbeiatbwmtktbpkc.supabase.co/auth/v1/.well-known/jwks.json"

# Preferred email provider: Resend (https://resend.com). When RESEND_API_KEY is set,
# app/api/send-email delivers through the Resend API and the SMTP settings below are ignored.
# The sending domain (in SMTP_FROM) must be verified in the Resend dashboard first.
RESEND_API_KEY="re_YOUR_RESEND_API_KEY"

# Fallback server-side SMTP settings, used by app/api/send-email only when RESEND_API_KEY
# is not set. These deliver the transactional emails that get logged into the email_logs
# table (customer welcome, admin alerts, meeting invites). Without either provider
# configured, emails are still logged but never sent.
# Prefer configuring these in Vercel environment variables, not in source code.
SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="service@cargogrid.net"
SMTP_PASS="YOUR_SMTP_PASSWORD"
SMTP_FROM="CargoGrid OS <service@cargogrid.net>"

# Optional public app URL for callbacks and self-referential links.
NEXT_PUBLIC_APP_URL="https://cargogrid.net"
